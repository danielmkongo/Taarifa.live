# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USERNAME=taarifa
MONGO_PASSWORD=change_me_strong_password
MONGO_DB=taarifa

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── MQTT ─────────────────────────────────────────────────────────────────────
MQTT_USERNAME=taarifa_broker
MQTT_PASSWORD=change_me_mqtt_password

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_min_32_chars_xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_xxxxxxxx

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@taarifa.live

# ── Weather API (OpenWeatherMap) ──────────────────────────────────────────────
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://taarifa.live
NODE_ENV=production
